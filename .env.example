# Copy to .env for local runs. In production these are set on the container.

# Enable the backup feature and expose backup options in the web UI.
BACKUP=false

# Web UI port.
WEBUI_PORT=8080

# Device label shown in Obsidian Sync history.
DEVICE_NAME=obsidian-sync-station

# Optional: mirror each snapshot to a second destination (map a /mirror volume).
MIRROR=false

# Optional: default ntfy topic URL for push notifications (also settable in UI).
# NTFY_URL=https://ntfy.example.com/obsidian
# Optional: ntfy access token (Bearer) for auth-protected servers. Public topics
# need no token. Also settable in the UI.
# NTFY_TOKEN=tk_xxxxxxxx

# Optional: off-site backups via restic. Set a repository to enable it; runs
# after each local backup. Repo is encrypted with RESTIC_PASSWORD.
#   Local:  RESTIC_REPOSITORY=/backup/restic
#   S3:     RESTIC_REPOSITORY=s3:s3.amazonaws.com/your-bucket   (+ AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
#   B2:     RESTIC_REPOSITORY=b2:your-bucket:path               (+ B2_ACCOUNT_ID / B2_ACCOUNT_KEY)
#   SFTP:   RESTIC_REPOSITORY=sftp:user@host:/path
# RESTIC_REPOSITORY=
# RESTIC_PASSWORD=

# Paths inside the container (defaults are fine; map volumes to them).
# CONFIG_DIR=/config
# VAULT_DIR=/vault
# BACKUP_DIR=/backup
# MIRROR_DIR=/mirror
