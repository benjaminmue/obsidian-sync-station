{
  "name": "obsidian-sync-station",
  "version": "0.5.6",
  "description": "Web UI + Docker container that keeps an Obsidian vault synced via Obsidian's official headless Sync client, with optional local backups. Built for Unraid.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "obsidian-sync-station": "src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test \"test/*.test.js\""
  },
  "license": "MIT",
  "author": "benjaminmue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benjaminmue/obsidian-sync-station.git"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.1.1",
    "fastify": "^5.2.1",
    "node-cron": "^3.0.3"
  }
}
